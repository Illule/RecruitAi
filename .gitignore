# ═══════════════════════════════
#  RecruitAI — root .gitignore
# ═══════════════════════════════

# ── Secrets (NEVER commit) ──────────────────────────────────────────
backend/.env
.env
.env.*
!.env.example
!backend/.env.example

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
MANIFEST
.python-version

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# ── Node / React / Vite ─────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / Editor ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ─────────────────────────────────────────────────────────────
*.bak
*.tmp
